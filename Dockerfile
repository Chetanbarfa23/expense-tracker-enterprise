# ======================================
# Base Image
# ======================================

FROM python:3.11-slim

# ======================================
# Working Directory
# ======================================

WORKDIR /app

# ======================================
# Copy Requirements
# ======================================

COPY requirements.txt .

# ======================================
# Install Dependencies
# ======================================

RUN pip install --no-cache-dir -r requirements.txt

# ======================================
# Copy Project Files
# ======================================

COPY . .

# ======================================
# Expose Flask Port
# ======================================

EXPOSE 5000

# ======================================
# Start Application
# ======================================

CMD ["python", "run.py"]